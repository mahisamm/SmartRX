# Copy to .env and fill in. Backend runs in stub mode (no real Gemini) until GEMINI_API_KEY is set.
DATABASE_URL=sqlite:///./smartrx.db
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=10485760
TESSERACT_CONF_FLOOR=60
