# Copy to .env and fill in. Backend runs in stub mode (no real Gemini) until GEMINI_API_KEY is set.
DATABASE_URL=sqlite:///./smartrx.db
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=10485760
TESSERACT_CONF_FLOOR=60
# Comma-separated allowed CORS origins (add your production domain here)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
